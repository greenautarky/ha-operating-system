#!/bin/sh
# ga-dns-inject — Inject GA service DNS entries into Supervisor CoreDNS
#
# The Supervisor manages its own DNS via hassio_dns (CoreDNS).
# Host /etc/hosts entries are NOT visible inside the Supervisor containers.
# This script appends GA service entries to the CoreDNS hosts file
# after the Supervisor starts.
#
# DNS entries are defined in /usr/share/ga-defaults/dns-inject.conf
# Format: one "IP HOSTNAME" per line
#
set -e

INJECT_FILE="/usr/share/ga-defaults/dns-inject.conf"
DNS_HOSTS="/mnt/data/supervisor/dns/hosts"
MARKER="# GA-injected"

if [ ! -f "$INJECT_FILE" ]; then
  echo "ga-dns-inject: no inject file at $INJECT_FILE — skipping"
  exit 0
fi

# Wait for Supervisor to be fully running (not just started)
echo "ga-dns-inject: waiting for Supervisor..."
RETRIES=60
while [ "$RETRIES" -gt 0 ]; do
  # Check if hassio_dns container is running AND hosts file exists
  if docker inspect hassio_dns --format '{{.State.Running}}' 2>/dev/null | grep -q 'true' \
     && [ -f "$DNS_HOSTS" ]; then
    # Also wait for Supervisor to finish startup (all addons loaded)
    if ha supervisor info 2>/dev/null | grep -q 'state: started' 2>/dev/null; then
      echo "ga-dns-inject: Supervisor is running"
      break
    fi
  fi
  sleep 5
  RETRIES=$((RETRIES - 1))
done

if [ ! -f "$DNS_HOSTS" ]; then
  echo "ga-dns-inject: $DNS_HOSTS not found after 5 min — giving up"
  exit 1
fi

# Remove old injected entries (idempotent)
sed -i "/$MARKER/d" "$DNS_HOSTS"

# Append new entries
while IFS= read -r line; do
  [ -z "$line" ] && continue
  case "$line" in \#*) continue ;; esac
  echo "$line $MARKER" >> "$DNS_HOSTS"
done < "$INJECT_FILE"

COUNT=$(grep -c "$MARKER" "$DNS_HOSTS")
echo "ga-dns-inject: injected $COUNT DNS entries into CoreDNS"

# Restart hassio_dns so CoreDNS reloads the hosts file
docker restart hassio_dns >/dev/null 2>&1 && \
  echo "ga-dns-inject: restarted hassio_dns to apply changes" || \
  echo "ga-dns-inject: WARNING — could not restart hassio_dns"
