#!/bin/sh
# ga-openstick-autoconnect — Scan for OpenStick WiFi and create persistent connection
#
# Scans for GA-XXXX SSIDs, derives PSK via HMAC-SHA256, creates a persistent
# NM connection with autoconnect=yes. NM then manages failover automatically
# via route metrics:
#
#   Ethernet (100) > OpenStick (500) > RNDIS (700) > Install WiFi (800)
#
# Run by:
#   - ga-openstick-autoconnect.timer (every 5 min — picks up new sticks)
#   - ga-openstick-autoconnect.service (once at boot)
#
set -e

KEY_FILE="/usr/share/ga-wifi/openstick-wifi.key"
SSID_PREFIX="GA-"
CONN_NAME="openstick-auto"
COOLDOWN_FILE="/mnt/data/.ga-openstick-cooldown"
COOLDOWN_SECS=300
LOG_TAG="ga-openstick"

log() { logger -t "$LOG_TAG" "$1"; echo "$LOG_TAG: $1"; }

# 1. Check if secret exists (feature disabled without key)
if [ ! -f "$KEY_FILE" ]; then
  exit 0
fi

# 2. Check if already connected — nothing to do
if nmcli -t -f NAME connection show --active 2>/dev/null | grep -q "$CONN_NAME"; then
  exit 0
fi

# 3. Check cooldown (avoid scan loops when no stick in range)
if [ -f "$COOLDOWN_FILE" ]; then
  COOLDOWN_UNTIL=$(cat "$COOLDOWN_FILE" 2>/dev/null || echo 0)
  NOW=$(date +%s)
  if [ "$NOW" -lt "$COOLDOWN_UNTIL" ]; then
    exit 0
  fi
  rm -f "$COOLDOWN_FILE"
fi

log "Scanning for OpenStick WiFi..."

# 4. WiFi scan (multiple rescans for reliability)
for _scan in 1 2 3; do
  nmcli dev wifi rescan 2>/dev/null
  sleep 5
done

# 5. Find GA-* SSIDs sorted by signal strength
GA_SSIDS=$(nmcli -t -f SSID,SIGNAL dev wifi list 2>/dev/null \
  | grep "^${SSID_PREFIX}" \
  | sort -t: -k2 -rn \
  | cut -d: -f1 \
  | head -5)

if [ -z "$GA_SSIDS" ]; then
  log "No GA-* SSIDs found — cooldown ${COOLDOWN_SECS}s"
  echo $(( $(date +%s) + COOLDOWN_SECS )) > "$COOLDOWN_FILE"
  exit 0
fi

SECRET=$(cat "$KEY_FILE" | tr -d '\n')

# 6. Try each SSID — create persistent autoconnect connection
for SSID in $GA_SSIDS; do
  # Validate format: GA- followed by 4 digits
  if ! echo "$SSID" | grep -qE "^GA-[0-9]{4}$"; then
    continue
  fi

  # Derive PSK
  PSK=$(echo -n "$SSID" | openssl dgst -sha256 -hmac "$SECRET" 2>/dev/null | cut -d' ' -f2 | cut -c1-16)
  if [ ${#PSK} -ne 16 ]; then
    log "HMAC derivation failed for $SSID"
    continue
  fi

  log "Creating persistent connection for $SSID..."

  # Remove old connection if exists
  nmcli connection delete "$CONN_NAME" 2>/dev/null || true

  # Create persistent connection with autoconnect + correct priority
  if nmcli connection add type wifi ifname wlan0 \
       con-name "$CONN_NAME" \
       ssid "$SSID" \
       wifi-sec.key-mgmt wpa-psk \
       wifi-sec.psk "$PSK" \
       connection.autoconnect yes \
       connection.autoconnect-priority 10 \
       ipv4.route-metric 500 \
       2>/dev/null; then

    log "Connection '$CONN_NAME' created for $SSID (autoconnect=yes, priority=10, metric=500)"

    # Activate now (NM will auto-activate on future boots/scans)
    nmcli connection up "$CONN_NAME" 2>/dev/null || true

    # Wait for DHCP
    sleep 10

    # Verify internet
    if curl -sf --connect-timeout 10 http://checkonline.greenautarky.com/online.txt 2>/dev/null | grep -q "NetworkManager is online"; then
      log "Connected to $SSID — internet verified. Connection is persistent."
      rm -f "$COOLDOWN_FILE"
      exit 0
    else
      log "$SSID connected but no internet — removing connection"
      nmcli connection delete "$CONN_NAME" 2>/dev/null || true
    fi
  else
    log "Failed to create connection for $SSID"
  fi
done

log "All GA-* SSIDs failed — cooldown ${COOLDOWN_SECS}s"
echo $(( $(date +%s) + COOLDOWN_SECS )) > "$COOLDOWN_FILE"
