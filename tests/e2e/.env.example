# Required: device IP (port 8123 is assumed)
DEVICE_IP=192.168.1.100

# Optional: override full URL (takes precedence over DEVICE_IP)
# DEVICE_URL=http://homeassistant.local:8123

# Optional: enables dashboard tests
HA_ADMIN_USER=admin
HA_ADMIN_PASS=changeme

# Optional: use a pre-created long-lived token instead of username/password
# Create via HA profile page → Long-Lived Access Tokens
# HA_TOKEN=

# Optional: run destructive onboarding flow tests
# WARNING: deletes GA onboarding state and restarts HA Core on the device
# RESET_ONBOARDING=1

# Optional: SSH settings for resetOnboarding fixture
SSH_PORT=22222
SSH_KEY=~/.ssh/ha-ihost.pem
