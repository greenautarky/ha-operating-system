# GA App Tests — Environment Variables
#
# Copy to .env and fill in for local runs:
#   cp tests/app/.env.example tests/app/.env
#
# Then run:
#   RUN_APP_TESTS=1 tests/run_app_tests.sh --ssh root@<device-ip> --admin-pass <pass>

# Required: opt-in guard (prevents accidental runs — set to 1 to enable)
# RUN_APP_TESTS=1

# Required: iHost device IP address
DEVICE_IP=192.168.1.100

# Optional: override full URL (default: http://$DEVICE_IP:8123)
# DEVICE_URL=http://192.168.1.100:8123

# Required for login tests: HA admin password
HA_ADMIN_PASS=changeme

# Optional: HA admin username (default: admin)
HA_ADMIN_USER=admin

# Optional: Android emulator AVD name (default: ga-test, created by android/setup.sh)
AVD_NAME=ga-test

# Optional: path to HA Companion APK (default: tests/app/android/ha-companion.apk)
# Must be a debug/debuggable APK to enable WebView automation.
# APK_PATH=/path/to/ha-companion-debug.apk

# Optional: SSH settings for onboarding reset
SSH_PORT=22222
SSH_KEY=~/.ssh/ha-ihost.pem
